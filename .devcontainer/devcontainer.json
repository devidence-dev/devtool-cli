{
  "name": "devtool-cli (Go 1.26 trixie)",
  "image": "mcr.microsoft.com/devcontainers/go:dev-1.26-trixie",
  "remoteUser": "vscode",
  // SSH del host + git del host (sin depender del feature de git)
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached,readonly",
    "source=/usr/bin/git,target=/usr/bin/git,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock",
    // Para que el Go toolchain no llene el workspace con cache
    "GOPATH": "/go",
    "GOMODCACHE": "/go/pkg/mod"
  },
  "features": {
    // Solo zsh/ohmyzsh — git lo traemos del host, más liviano
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "true",
      "configureZshAsDefaultShell": "true",
      "installOhMyZsh": "true",
      "upgradePackages": "true"
    }
  },
  "onCreateCommand": "go install github.com/spf13/cobra-cli@latest && go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest",
  "postCreateCommand": "[ -f go.mod ] && go mod download && go mod tidy || echo 'No go.mod found, skipping'",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        // "golang.go-nightly",         // opcional, para features bleeding edge
        "ms-vscode.vscode-json",
        "redhat.vscode-yaml",
        "streetsidesoftware.code-spell-checker",
        "github.copilot",
        "anthropic.claude-code",
        "ms-vscode-remote.remote-containers"
      ],
      "settings": {
        // Go core
        "go.useLanguageServer": true,
        "go.toolsManagement.checkForUpdates": "local",
        "go.lintTool": "golangci-lint",
        "go.lintOnSave": "package",
        // Editor
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
        // Sin spam de telemetría del gopls
        "go.survey.prompt": false
      }
    }
  }
}